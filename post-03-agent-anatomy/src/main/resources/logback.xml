<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level [%logger{20}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Show Jentic internal logs at WARN to keep output readable -->
    <logger name="dev.jentic" level="WARN"/>

    <!-- Our agents log at INFO -->
    <logger name="dev.jentic.blog" level="INFO"/>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
